<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Geometries use a 24×24 coord space; consumers render as strokes (thickness ~1.6, round caps). -->

    <GeometryGroup x:Key="GeomAll" FillRule="Nonzero">
        <RectangleGeometry Rect="4,5,16,3" RadiusX="1" RadiusY="1"/>
        <RectangleGeometry Rect="4,11,16,3" RadiusX="1" RadiusY="1"/>
        <RectangleGeometry Rect="4,17,10,3" RadiusX="1" RadiusY="1"/>
    </GeometryGroup>

    <PathGeometry x:Key="GeomPin" Figures="M12,2 L12,9 M8,9 L16,9 L14.8,15.2 L12,18 L9.2,15.2 L8,9 Z M12,18 L12,22"/>

    <PathGeometry x:Key="GeomPinFill" Figures="M12,2 L12,9 L16,9 L15,15 L13,15 L13,20 L12,22 L11,20 L11,15 L9,15 L8,9 L12,9 Z"/>

    <PathGeometry x:Key="GeomText" Figures="M5,6 L19,6 M12,6 L12,19 M8,19 L16,19"/>

    <PathGeometry x:Key="GeomCode" Figures="M8,7 L3,12 L8,17 M16,7 L21,12 L16,17 M14,5 L10,19"/>

    <PathGeometry x:Key="GeomLink" Figures="M10,14 C8,12 8,9 10,7 L13,4 C15,2 18,2 20,4 C22,6 22,9 20,11 L18.5,12.5 M14,10 C16,12 16,15 14,17 L11,20 C9,22 6,22 4,20 C2,18 2,15 4,13 L5.5,11.5"/>

    <GeometryGroup x:Key="GeomImage">
        <RectangleGeometry Rect="3,5,18,14" RadiusX="2" RadiusY="2"/>
        <EllipseGeometry Center="9,10" RadiusX="1.5" RadiusY="1.5"/>
        <PathGeometry Figures="M21,16 L16,12 L8,19"/>
    </GeometryGroup>

    <GeometryGroup x:Key="GeomColor">
        <EllipseGeometry Center="12,12" RadiusX="8" RadiusY="8"/>
        <EllipseGeometry Center="9,9"   RadiusX="1" RadiusY="1"/>
        <EllipseGeometry Center="15,9"  RadiusX="1" RadiusY="1"/>
        <EllipseGeometry Center="9,15"  RadiusX="1" RadiusY="1"/>
        <EllipseGeometry Center="15,15" RadiusX="1" RadiusY="1"/>
    </GeometryGroup>

    <PathGeometry x:Key="GeomFile" Figures="M14,3 L7,3 C5.9,3 5,3.9 5,5 L5,19 C5,20.1 5.9,21 7,21 L17,21 C18.1,21 19,20.1 19,19 L19,8 L14,3 Z M14,3 L14,8 L19,8"/>

    <PathGeometry x:Key="GeomSearch" Figures="M11,4 A7,7 0 1,0 11,18 A7,7 0 1,0 11,4 M16.7,16.7 L21,21"/>

    <PathGeometry x:Key="GeomClock" Figures="M12,3 A9,9 0 1,0 12,21 A9,9 0 1,0 12,3 M12,7 L12,12 L15,14"/>

    <PathGeometry x:Key="GeomPlus" Figures="M12,5 L12,19 M5,12 L19,12"/>

    <PathGeometry x:Key="GeomX" Figures="M6,6 L18,18 M18,6 L6,18"/>

    <!-- Arrow-down-to-tray glyph for "download" / "install update" affordances. -->
    <PathGeometry x:Key="GeomDownload"
                  Figures="M12,3 L12,15 M7,10 L12,15 L17,10 M5,19 L19,19"/>

    <GeometryGroup x:Key="GeomCopy">
        <RectangleGeometry Rect="9,9,11,11" RadiusX="2" RadiusY="2"/>
        <PathGeometry Figures="M5,15 L5,5 C5,3.9 5.9,3 7,3 L17,3"/>
    </GeometryGroup>

    <PathGeometry x:Key="GeomTrash" Figures="M4,7 L20,7 M10,7 L10,4 L14,4 L14,7 M6,7 L7,20 L17,20 L18,7"/>

    <PathGeometry x:Key="GeomSettings" Figures="M12,9 A3,3 0 1,0 12,15 A3,3 0 1,0 12,9"/>

    <!-- Gear for the settings entry point. Stroked as a 12-tooth cog with a
         hollow centre so the 1.6px stroke stays readable at 16×16. -->
    <PathGeometry x:Key="GeomGear"
                  Figures="M12,8 A4,4 0 1,0 12,16 A4,4 0 1,0 12,8
                           M12,2 L12,5 M12,19 L12,22
                           M2,12 L5,12 M19,12 L22,12
                           M5,5 L7,7 M17,17 L19,19
                           M19,5 L17,7 M7,17 L5,19"/>

    <!-- Swap/transform glyph: two horizontal arrows pointing opposite directions.
         Reads as "convert" without being as literal as a gear. -->
    <PathGeometry x:Key="GeomTransform"
                  Figures="M4,9 L18,9 L14,5 M18,9 L14,13
                           M20,15 L6,15 L10,11 M6,15 L10,19"/>

    <!-- "T" glyph used for the template badge on pinned clips that contain
         {token} substitutions. -->
    <PathGeometry x:Key="GeomTemplate"
                  Figures="M5,6 L19,6 M12,6 L12,19"/>

</ResourceDictionary>
