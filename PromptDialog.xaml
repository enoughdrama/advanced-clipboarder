<Window x:Class="Clipboarder.PromptDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" ShowInTaskbar="False"
        WindowStartupLocation="CenterScreen"
        SizeToContent="Height" Width="440"
        FontFamily="{StaticResource UiFont}"
        FontWeight="Medium"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Grayscale"
        TextOptions.TextHintingMode="Animated"
        RenderOptions.BitmapScalingMode="HighQuality"
        UseLayoutRounding="True" SnapsToDevicePixels="True">
    <Border CornerRadius="14" Padding="20"
            Background="#F0141218"
            BorderBrush="{StaticResource Line2}" BorderThickness="1"
            MouseLeftButtonDown="OnDrag">
        <Border.Effect>
            <DropShadowEffect BlurRadius="32" ShadowDepth="10" Color="Black" Opacity="0.55"/>
        </Border.Effect>
        <StackPanel>
            <DockPanel Margin="0,0,0,12">
                <Border DockPanel.Dock="Left"
                        Width="36" Height="36" CornerRadius="18"
                        Background="#1F9E7BF0" Margin="0,0,12,0"
                        VerticalAlignment="Top">
                    <Path Data="M4,8 L12,14 L20,8 M4,16 L20,16"
                          Stroke="{StaticResource Accent}" StrokeThickness="1.8"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                          Width="16" Height="16" Stretch="Uniform"
                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel>
                    <TextBlock Text="Fill template"
                               Foreground="{StaticResource Fg0}"
                               FontSize="15" FontWeight="SemiBold"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="Values will be substituted on paste."
                               Foreground="{StaticResource Fg2}"
                               FontSize="12"/>
                </StackPanel>
            </DockPanel>

            <ItemsControl x:Name="FieldsHost">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="{Binding Label}"
                                       Foreground="{StaticResource Fg2}"
                                       FontSize="11" FontWeight="SemiBold"
                                       Typography.Capitals="AllSmallCaps"
                                       Margin="2,0,0,4"/>
                            <Border CornerRadius="8" Padding="10,0" BorderThickness="1" Height="34">
                                <Border.Background><SolidColorBrush Color="#14FFFFFF"/></Border.Background>
                                <Border.BorderBrush><SolidColorBrush Color="#1AFFFFFF"/></Border.BorderBrush>
                                <TextBox Style="{StaticResource SearchBox}"
                                         Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                         Tag="{Binding}"
                                         Loaded="OnFieldLoaded"
                                         VerticalAlignment="Center"/>
                            </Border>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                <Button Click="OnCancel"
                        Content="Cancel"
                        Height="32" Padding="14,0" Margin="0,0,8,0"
                        Cursor="Hand" IsCancel="True">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" CornerRadius="8"
                                                Background="#0AFFFFFF"
                                                BorderBrush="{StaticResource Line2}"
                                                BorderThickness="1"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              TextBlock.Foreground="{StaticResource Fg1}"
                                                              TextBlock.FontSize="12"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="#14FFFFFF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Click="OnConfirm"
                        Content="Paste"
                        Height="32" Padding="14,0"
                        Cursor="Hand" IsDefault="True">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" CornerRadius="8"
                                                Background="{StaticResource Accent}"
                                                BorderThickness="0"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              TextBlock.Foreground="White"
                                                              TextBlock.FontSize="12"
                                                              TextBlock.FontWeight="SemiBold"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="#B09AF5"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
