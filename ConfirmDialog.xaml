<Window x:Class="Clipboarder.ConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        SizeToContent="Height" Width="420"
        FontFamily="{StaticResource UiFont}"
        FontWeight="Medium"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Grayscale"
        UseLayoutRounding="True" SnapsToDevicePixels="True">
    <Border CornerRadius="14" Padding="20"
            Background="#F0141218"
            BorderBrush="{StaticResource Line2}" BorderThickness="1"
            MouseLeftButtonDown="OnDrag">
        <Border.Effect>
            <DropShadowEffect BlurRadius="32" ShadowDepth="10" Color="Black" Opacity="0.55"/>
        </Border.Effect>
        <StackPanel>
            <DockPanel Margin="0,0,0,10">
                <Border DockPanel.Dock="Left"
                        Width="36" Height="36" CornerRadius="18"
                        Background="#1FE57A6B" Margin="0,0,12,0"
                        VerticalAlignment="Top">
                    <Path Data="{StaticResource GeomTrash}"
                          Stroke="{StaticResource Danger}" StrokeThickness="1.8"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                          Width="16" Height="16" Stretch="Uniform"
                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel>
                    <TextBlock x:Name="TitleText"
                               Foreground="{StaticResource Fg0}"
                               FontSize="15" FontWeight="SemiBold"
                               Margin="0,0,0,4"/>
                    <TextBlock x:Name="MessageText"
                               Foreground="{StaticResource Fg2}"
                               FontSize="13" TextWrapping="Wrap"/>
                </StackPanel>
            </DockPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                <Button x:Name="CancelBtn" Click="OnCancel"
                        Content="Cancel"
                        Height="32" Padding="14,0" Margin="0,0,8,0"
                        Cursor="Hand" IsCancel="True">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" CornerRadius="8"
                                                Background="#0AFFFFFF"
                                                BorderBrush="{StaticResource Line2}"
                                                BorderThickness="1"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              TextBlock.Foreground="{StaticResource Fg1}"
                                                              TextBlock.FontSize="12"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="#14FFFFFF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                <Button x:Name="ConfirmBtn" Click="OnConfirm"
                        Content="Delete"
                        Height="32" Padding="14,0"
                        Cursor="Hand" IsDefault="True">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" CornerRadius="8"
                                                Background="#E57A6B"
                                                BorderThickness="0"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              TextBlock.Foreground="White"
                                                              TextBlock.FontSize="12"
                                                              TextBlock.FontWeight="SemiBold"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="#EF8A7C"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="#D56A5B"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
