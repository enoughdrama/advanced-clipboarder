<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:conv="clr-namespace:Clipboarder.Converters">

    <conv:HexToBrushConverter x:Key="HexToBrush"/>
    <conv:NullToVisibilityConverter x:Key="NotNullToVis"/>
    <conv:ImageCaptionConverter x:Key="ImageCaption"/>
    <conv:PathToImageConverter x:Key="PathToImage"/>

    <DataTemplate x:Key="CardBody_Text">
        <TextBlock Text="{Binding Content}"
                   Foreground="{StaticResource Fg0}"
                   FontFamily="{StaticResource UiFont}"
                   FontSize="13" LineHeight="20" LineStackingStrategy="BlockLineHeight"
                   TextWrapping="Wrap" TextTrimming="CharacterEllipsis"
                   MaxHeight="42"/>
    </DataTemplate>

    <DataTemplate x:Key="CardBody_Email">
        <TextBlock Text="{Binding Content}"
                   Foreground="{StaticResource TypeEmailBrush}"
                   FontFamily="{StaticResource MonoFont}" FontSize="12"
                   TextTrimming="CharacterEllipsis"/>
    </DataTemplate>

    <DataTemplate x:Key="CardBody_Link">
        <TextBlock Text="{Binding Content}"
                   Foreground="{StaticResource TypeLinkBrush}"
                   FontFamily="{StaticResource UiFont}" FontSize="13"
                   TextWrapping="Wrap" TextTrimming="CharacterEllipsis"
                   MaxHeight="42"/>
    </DataTemplate>

    <DataTemplate x:Key="CardBody_Code">
        <Border Background="#47000000" BorderBrush="{StaticResource Line}" BorderThickness="1"
                CornerRadius="6" Padding="10,8" MaxHeight="84" ClipToBounds="True">
            <TextBlock Text="{Binding Content}"
                       Foreground="{StaticResource Fg0}"
                       FontFamily="{StaticResource MonoFont}" FontSize="11.5"
                       TextTrimming="CharacterEllipsis"
                       TextWrapping="NoWrap"/>
        </Border>
    </DataTemplate>

    <DataTemplate x:Key="CardBody_Image">
        <Border Height="120" CornerRadius="8" BorderBrush="{StaticResource Line}" BorderThickness="1"
                ClipToBounds="True">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Offset="0" Color="#FF2A2530"/>
                    <GradientStop Offset="1" Color="#FF15131A"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Image Source="{Binding Content, Converter={StaticResource PathToImage}}"
                       Stretch="UniformToFill"
                       RenderOptions.BitmapScalingMode="Fant"/>
                <Border Background="#99000000" CornerRadius="4" Padding="7,3"
                        HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="6">
                    <TextBlock Foreground="{StaticResource Fg1}"
                               FontFamily="{StaticResource MonoFont}" FontSize="10">
                        <TextBlock.Text>
                            <MultiBinding Converter="{StaticResource ImageCaption}">
                                <Binding Path="Content"/>
                                <Binding Path="Width"/>
                                <Binding Path="Height"/>
                                <Binding Path="FileSize"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                </Border>
            </Grid>
        </Border>
    </DataTemplate>

    <DataTemplate x:Key="CardBody_Color">
        <StackPanel Orientation="Horizontal">
            <Border Width="40" Height="40" CornerRadius="8"
                    Background="{Binding Content, Converter={StaticResource HexToBrush}}"
                    BorderBrush="#26FFFFFF" BorderThickness="1"/>
            <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                <TextBlock Text="{Binding Content}"
                           Foreground="{StaticResource Fg0}"
                           FontFamily="{StaticResource MonoFont}"
                           FontSize="14" FontWeight="SemiBold"/>
                <ItemsControl Margin="0,4,0,0" ItemsSource="{Binding Palette}"
                              Visibility="{Binding Palette, Converter={StaticResource NotNullToVis}}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="16" Height="16" Margin="0,0,5,0" CornerRadius="4"
                                    Background="{Binding Converter={StaticResource HexToBrush}}"
                                    BorderBrush="#1AFFFFFF" BorderThickness="1"
                                    ToolTip="{Binding}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </StackPanel>
    </DataTemplate>

    <DataTemplate x:Key="CardBody_File">
        <StackPanel Orientation="Horizontal">
            <TextBlock Text="{Binding Content}"
                       Foreground="{StaticResource Fg0}"
                       FontFamily="{StaticResource MonoFont}" FontSize="12"
                       TextTrimming="CharacterEllipsis"/>
            <TextBlock Text="{Binding FileSize, StringFormat=' · {0}'}"
                       Foreground="{StaticResource Fg3}"
                       FontFamily="{StaticResource MonoFont}" FontSize="12"/>
        </StackPanel>
    </DataTemplate>

    <!-- "Big" = short numeric codes (2FA / OTP) displayed large and monospaced. -->
    <DataTemplate x:Key="CardBody_Big">
        <TextBlock Text="{Binding Content}"
                   Foreground="{StaticResource Fg0}"
                   FontFamily="{StaticResource MonoFont}"
                   FontSize="20" FontWeight="SemiBold"/>
    </DataTemplate>

</ResourceDictionary>
